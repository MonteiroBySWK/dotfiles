# Configurações Globais
max-history=5
sort=-time
layer=overlay
anchor=top-right
margin=20

# Estética Sharp/Clean
font=JetBrainsMono Nerd Font 10
width=300
#height=100
padding=15
border-size=1
border-radius=4
icons=1
max-icon-size=32

# Cores (Glass Dark)
background-color=#11111be6
text-color=#cdd6f4
border-color=#313244
progress-color=over #89b4fa

# Comportamento
default-timeout=4000

[urgency=high]
border-color=#f38ba8
default-timeout=0
